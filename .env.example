# Copy this file to .env and add your credentials

# STAC Catalog URL (publicly accessible, no authentication required)
STAC_URL=https://stac.core.eopf.eodc.eu

# Claude API (required if using llm_provider: "claude" in config.yaml)
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# OVH AI Endpoints (required if using llm_provider: "ovh" in config.yaml)
# Get your token from: https://endpoints.ai.cloud.ovh.net/
OVH_AI_ENDPOINTS_ACCESS_TOKEN=your-token-here

# CDSE S3 Credentials (OPTIONAL - only needed for downloading Zarr data via S3)
# Note: HTTPS Zarr URLs work without credentials. S3 URLs require these.
# Get credentials from: https://dataspace.copernicus.eu/
ACCESS_KEY_ID=your-access-key-here
SECRET_ACCESS_KEY=your-secret-key-here
